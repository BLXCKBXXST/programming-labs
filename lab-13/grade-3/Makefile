# -------------------------------------------------------
# Makefile — автоматизируем сборку вместо ручных команд
# запуск: make        → собирает всё
# запуск: make clean  → удаляет скомпилированные файлы
# -------------------------------------------------------

# переменные — чтобы не переписывать одно и то же несколько раз
CC     = gcc                  # компилятор
CFLAGS = -Wall -I include     # -Wall: выводить все предупреждения; -I include: где искать .h
AR     = ar                   # утилита для создания статической библиотеки
LIB    = libsneakers.a        # имя статической библиотеки
OBJ    = src/sneakers.o       # имя объектного файла
BIN    = sneakers             # имя готовой программы

# цель по умолчанию — выполняется первой при простом make
all: $(BIN)

# шаг 1: компилируем sneakers.c в объектный файл sneakers.o
# $< — это первый файл-зависимость (sneakers.c)
# $@ — это цель (sneakers.o)
$(OBJ): src/sneakers.c include/sneakers.h
	$(CC) $(CFLAGS) -c $< -o $@

# шаг 2: создаём статическую библиотеку .a из .o
# rcs: r=добавить, c=создать если нет, s=индексировать
# $^ — все зависимости
$(LIB): $(OBJ)
	$(AR) rcs $@ $^

# шаг 3: линкуем main.c + библиотека → готовая программа
$(BIN): src/main.c $(LIB)
	$(CC) $(CFLAGS) $^ -o $@

# clean: удаляем всё скомпилированное
clean:
	rm -f $(OBJ) $(LIB) $(BIN)

# PHONY — говорим make что all и clean — это не файлы, а команды
.PHONY: all clean
